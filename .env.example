# ─────────────────────────────────────────────────────────────
#  Get your free API key at: https://console.groq.com
# ─────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Optional overrides (defaults shown) ──────────────────────

# Models (do not change unless you know what you're doing)
# CHUNK_MODEL=llama-3.1-8b-instant
# REDUCE_MODEL=llama-3.3-70b-versatile

# Summarization routing thresholds (in tokens)
# STUFF_THRESHOLD_TOKENS=3000
# HIERARCHICAL_THRESHOLD_TOKENS=80000

# Chunking parameters
# CHUNK_SIZE_CHARS=2500
# CHUNK_OVERLAP_CHARS=250

# Rate limiting (Groq free tier: 30 RPM, 6000 TPM for 8B model)
# MAX_CONCURRENT_CHUNK_REQUESTS=3
# REQUEST_DELAY_SECONDS=2.0

# Quality refinement pass (set to false to speed things up)
# ENABLE_REFINEMENT=true

# Caching (set to false to disable disk cache)
# ENABLE_CACHE=true
# CACHE_DIR=.cache/summaries
